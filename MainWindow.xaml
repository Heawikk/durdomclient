<Window x:Class="DurdomClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:DurdomClient.Helpers"
        Title="Durdom Client"
        Icon="Assets/app.ico"
        Height="700" Width="980"
        MinHeight="580" MinWidth="820"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InverseBoolToVisibilityConverter x:Key="NotBoolToVisibility"/>
        <conv:EnumToBoolConverter x:Key="EnumBoolConverter"/>
        <conv:LogLevelToBrushConverter x:Key="LogLevelColor"/>
        <conv:PingToStringConverter x:Key="PingToString"/>
        <conv:PingToBrushConverter x:Key="PingToBrush"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D4DDF0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding Tag}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#4F6BFF"/>
            <Setter Property="Padding" Value="22,9"/>
            <Setter Property="Tag" Value="10"/>
        </Style>
        <Style x:Key="RedBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#E03A4A"/>
            <Setter Property="Padding" Value="22,9"/>
            <Setter Property="Tag" Value="10"/>
        </Style>
        <Style x:Key="SubtleBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#111728"/>
            <Setter Property="Foreground" Value="#8A9BB0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Tag" Value="8"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#0B0E18"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18"/>
        </Style>
        <Style x:Key="InnerCard" TargetType="Border">
            <Setter Property="Background" Value="#0F1420"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A8B5C8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#131B2C"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#182444"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="ToggleCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#9AABBD"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Box" Width="15" Height="15" CornerRadius="4"
                                    Background="Transparent"
                                    BorderBrush="#253350" BorderThickness="1.5"
                                    Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path x:Name="Mark"
                                      Data="M 2.5,7 L 6,10.5 L 12.5,4"
                                      Stroke="White" StrokeThickness="1.8"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"
                                      VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#4F6BFF"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#4F6BFF"/>
                                <Setter TargetName="Mark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#4F6BFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#9AABBD"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="15" Height="15" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse x:Name="Outer"
                                         Stroke="#253350" StrokeThickness="1.5"
                                         Fill="Transparent"/>
                                <Ellipse x:Name="Inner" Width="7" Height="7"
                                         Fill="#4F6BFF"
                                         Visibility="Collapsed"/>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Outer" Property="Stroke" Value="#4F6BFF"/>
                                <Setter TargetName="Inner" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Outer" Property="Stroke" Value="#4F6BFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Cap" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#3D5068"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            
        </Style>

        <Style x:Key="Sep" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="#111E34"/>
            <Setter Property="Margin" Value="0,10"/>
        </Style>
    </Window.Resources>

    <Border Background="#07080D" CornerRadius="16" BorderBrush="#1A2236" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>  
                <RowDefinition Height="*"/>  
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#07080D" CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                            <Ellipse.Fill>
                                <SolidColorBrush x:Name="TitleDot" Color="{Binding StatusColor}"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="DURDOM" FontSize="12" FontWeight="Bold"
                                   Foreground="#FFFFFF"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" CLIENT" FontSize="12" FontWeight="Light"
                                   Foreground="#3D5080"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="LangBtn" Content="RU"
                                Style="{StaticResource SubtleBtn}"
                                Click="LangToggle_Click"
                                Width="32" Height="24" FontSize="10"
                                Margin="0,0,8,0" Padding="0"/>
                        <Button Style="{StaticResource Btn}" Click="MinimizeClick"
                                Width="32" Height="32" Margin="0,0,4,0"
                                ToolTip="{DynamicResource StrMinimize}">
                            <Rectangle Width="10" Height="1.5" Fill="#5A6880"
                                       VerticalAlignment="Center"/>
                        </Button>
                        <Button Style="{StaticResource Btn}" Click="MaximizeClick"
                                Width="32" Height="32" Margin="0,0,4,0"
                                ToolTip="{DynamicResource StrMaximize}">
                            <Border Width="10" Height="10"
                                    BorderBrush="#5A6880" BorderThickness="1.5"
                                    Background="Transparent"
                                    VerticalAlignment="Center"/>
                        </Button>
                        <Button Style="{StaticResource Btn}" Click="CloseClick"
                                Width="32" Height="32"
                                ToolTip="{DynamicResource StrClose}">
                            <Grid Width="10" Height="10" VerticalAlignment="Center">
                                <Line X1="0" Y1="0" X2="10" Y2="10"
                                      Stroke="#5A6880" StrokeThickness="1.5"/>
                                <Line X1="10" Y1="0" X2="0" Y2="10"
                                      Stroke="#5A6880" StrokeThickness="1.5"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/> 
                    <ColumnDefinition Width="*"/>   
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#060710" CornerRadius="0,0,0,16">
                    <Grid Margin="14,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/> 
                            <RowDefinition Height="*"/>  
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/> 
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" CornerRadius="20" Padding="12,7"
                                Margin="0,0,0,16">
                            <Border.Background>
                                <SolidColorBrush x:Name="StatusPillBg" Color="#101A2E"/>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding StatusColor}"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="{Binding StatusText}"
                                           FontSize="12" Foreground="#8FA3BE"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Row="1" Text="{DynamicResource StrServers}" Style="{StaticResource Cap}"/>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding Servers}"
                                 SelectedItem="{Binding SelectedServer}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                       FontWeight="Medium"
                                                       Foreground="#C9D1E0"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="10" Foreground="#3D5080" Margin="0,2,0,0">
                                                <Run Text="{Binding Protocol}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding Address}"/>
                                                <Run Text=":"/>
                                                <Run Text="{Binding Port}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding PingMs, Converter={StaticResource PingToString}}"
                                                   Foreground="{Binding PingMs, Converter={StaticResource PingToBrush}}"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Margin="6,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="3" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="{DynamicResource StrPasteClipboard}"
                                    Style="{StaticResource SubtleBtn}"
                                    Command="{Binding AddServerFromClipboardCommand}"
                                    FontSize="11" HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="2" Content="{DynamicResource StrPingAll}"
                                    Style="{StaticResource SubtleBtn}"
                                    Command="{Binding PingServersCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={conv:InverseBoolConverter}}"
                                    FontSize="11" Padding="10,7"/>
                            <Button Grid.Column="4" Content="{DynamicResource StrRemove}"
                                    Style="{StaticResource SubtleBtn}"
                                    Command="{Binding RemoveServerCommand}"
                                    FontSize="11" HorizontalAlignment="Stretch"
                                    Foreground="#E03A4A"/>
                        </Grid>

                        <Border Grid.Row="4" Style="{StaticResource Sep}"/>

                        <Grid Grid.Row="4" Margin="0,12,0,6">
                            <TextBlock Text="{DynamicResource StrSubscriptions}" Style="{StaticResource Cap}"
                                       VerticalAlignment="Center" Margin="0"/>
                            <Button Content="{DynamicResource StrUpdateAll}"
                                    Style="{StaticResource SubtleBtn}"
                                    HorizontalAlignment="Right"
                                    Command="{Binding UpdateAllSubscriptionsCommand}"
                                    FontSize="10" Padding="8,4"/>
                        </Grid>

                        <ListBox Grid.Row="5"
                                 x:Name="SidebarSubList"
                                 ItemsSource="{Binding Settings.Subscriptions}"
                                 MaxHeight="110">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                   Foreground="#8FA3BE"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock FontSize="10" Foreground="#3D5080" Margin="0,1,0,0">
                                            <Run Text="{Binding ServerCount}"/>
                                            <Run Text=" servers"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="6" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="{DynamicResource StrAddSub}"
                                    Style="{StaticResource SubtleBtn}"
                                    Click="OpenSubscriptionWindow"
                                    FontSize="11" HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="2" Content="{DynamicResource StrRemove}"
                                    Style="{StaticResource SubtleBtn}"
                                    Click="RemoveSubscriptionClick"
                                    FontSize="11" HorizontalAlignment="Stretch"
                                    Foreground="#E03A4A"/>
                        </Grid>

                        <Border Grid.Row="7" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock FontSize="10" Foreground="#253450">
                                    <Run Text="socks5  127.0.0.1:"/>
                                    <Run Text="{Binding Settings.LocalSocksPort}" Foreground="#3D5080"/>
                                </TextBlock>
                                <TextBlock FontSize="10" Foreground="#253450" Margin="0,2,0,0">
                                    <Run Text="http    127.0.0.1:"/>
                                    <Run Text="{Binding Settings.LocalHttpPort}" Foreground="#3D5080"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="14,10,14,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>  
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="20,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedServer.Name, FallbackValue='—'}"
                                           FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                <TextBlock FontSize="11" Foreground="#3D5080" Margin="0,3,0,0">
                                    <Run Text="{Binding SelectedServer.Address, FallbackValue=''}"/>
                                    <Run Text=":"/>
                                    <Run Text="{Binding SelectedServer.Port, FallbackValue=''}"/>
                                    <Run Text="  "/>
                                    <Run Text="{Binding SelectedServer.Security, FallbackValue=''}"/>
                                    <Run Text="/"/>
                                    <Run Text="{Binding SelectedServer.Network, FallbackValue=''}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="{DynamicResource StrConnect}"
                                        Style="{StaticResource AccentBtn}"
                                        Command="{Binding ConnectCommand}"
                                        IsEnabled="{Binding IsBusy, Converter={conv:InverseBoolConverter}}"
                                        Visibility="{Binding IsConnected, Converter={StaticResource NotBoolToVisibility}}"
                                        FontSize="12" FontWeight="Bold"
                                       
                                        Margin="0,0,10,0"/>
                                <Button Content="{DynamicResource StrDisconnect}"
                                        Style="{StaticResource RedBtn}"
                                        Command="{Binding DisconnectCommand}"
                                        IsEnabled="{Binding IsBusy, Converter={conv:InverseBoolConverter}}"
                                        Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}"
                                        FontSize="12" FontWeight="Bold"
                                       
                                        Margin="0,0,10,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="20,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="{DynamicResource StrProxyMode}" Style="{StaticResource Cap}"/>
                                <CheckBox Content="{DynamicResource StrSystemProxy}"
                                          Style="{StaticResource ToggleCheck}"
                                          IsChecked="{Binding SystemProxyMode}"
                                          Margin="0,0,0,8"/>
                                <CheckBox Content="{DynamicResource StrTunMode}"
                                          Style="{StaticResource ToggleCheck}"
                                          IsChecked="{Binding TunMode}"/>
                            </StackPanel>

                            <Border Grid.Row="0" Grid.Column="1" Background="#12203A" Width="1" Margin="0,0,20,0"/>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="{DynamicResource StrRouting}" Style="{StaticResource Cap}"/>
                                <RadioButton Content="{DynamicResource StrRoutingGlobal}"
                                             Style="{StaticResource RadioStyle}"
                                             IsChecked="{Binding Settings.RoutingMode,
                                                 Converter={StaticResource EnumBoolConverter},
                                                 ConverterParameter=Global}"/>
                                <RadioButton Content="{DynamicResource StrRoutingGFW}"
                                             Style="{StaticResource RadioStyle}"
                                             IsChecked="{Binding Settings.RoutingMode,
                                                 Converter={StaticResource EnumBoolConverter},
                                                 ConverterParameter=GFWList}"/>
                                <RadioButton Content="{DynamicResource StrRoutingDirect}"
                                             Style="{StaticResource RadioStyle}"
                                             IsChecked="{Binding Settings.RoutingMode,
                                                 Converter={StaticResource EnumBoolConverter},
                                                 ConverterParameter=Direct}"/>
                            </StackPanel>

                            <Button Grid.Row="1" Grid.ColumnSpan="3"
                                    Content="{DynamicResource StrExclusions}"
                                    Style="{StaticResource SubtleBtn}"
                                    Command="{Binding OpenExclusionsCommand}"
                                    HorizontalAlignment="Left"
                                    Margin="0,12,0,0"
                                    FontSize="11"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="4" Style="{StaticResource Card}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="18,12,18,8">
                                <TextBlock Text="{DynamicResource StrLog}" Style="{StaticResource Cap}"
                                           VerticalAlignment="Center" Margin="0"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="{Binding PauseButtonText}"
                                            Style="{StaticResource SubtleBtn}"
                                            Command="{Binding ToggleLogPauseCommand}"
                                            FontSize="11" Padding="10,4" Margin="0,0,6,0"/>
                                    <Button Content="{DynamicResource StrClear}"
                                            Style="{StaticResource SubtleBtn}"
                                            Command="{Binding ClearLogCommand}"
                                            FontSize="11" Padding="10,4"/>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1" Background="Transparent"
                                    CornerRadius="0,0,14,14" Margin="1,0,1,1">
                                <ScrollViewer x:Name="LogScroller"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="14,0,14,12">
                                    <ItemsControl ItemsSource="{Binding LogEntries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="58"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Time}"
                                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                                               FontSize="11"
                                                               Foreground="#2D3E58"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Message}"
                                                               Foreground="{Binding Level, Converter={StaticResource LogLevelColor}}"
                                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
