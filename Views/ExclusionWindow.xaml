<Window x:Class="DurdomClient.Views.ExclusionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exclusions"
        Height="500" Width="480"
        Background="#080C14"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C9D1E0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0D1525"/>
            <Setter Property="Foreground" Value="#C9D1E0"/>
            <Setter Property="BorderBrush" Value="#1A2540"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#4F6BFF"/>
            <Setter Property="SelectionBrush" Value="#4F6BFF"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#4F6BFF"/>
            <Setter Property="Padding" Value="14,8"/>
        </Style>
        <Style x:Key="SubtleBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#141C2B"/>
            <Setter Property="Foreground" Value="#8892A4"/>
            <Setter Property="Padding" Value="12,7"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#1E0C10"/>
            <Setter Property="Foreground" Value="#E03A4A"/>
            <Setter Property="Padding" Value="12,7"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8FA3BE"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#111828"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#182444"/>
                                <Setter Property="Foreground" Value="#DDEEFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#080C14" CornerRadius="16" BorderBrush="#1A2540" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#080C14" CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid Margin="16,0">
                    <TextBlock Text="{DynamicResource StrExclusionsTitle}"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#3D5080" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Style="{StaticResource SubtleBtn}"
                            Click="CloseWindow"
                            Padding="8,4">
                        <Grid Width="10" Height="10">
                            <Line X1="0" Y1="0" X2="10" Y2="10"
                                  Stroke="#4A5568" StrokeThickness="1.5"/>
                            <Line X1="10" Y1="0" X2="0" Y2="10"
                                  Stroke="#4A5568" StrokeThickness="1.5"/>
                        </Grid>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="16,8,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" FontSize="11" Foreground="#3D5080"
                           Margin="0,0,0,10"
                           TextWrapping="Wrap"
                           Text="{DynamicResource StrExclusionsHint}"/>

                <Border Grid.Row="1" Background="#0B0E18" CornerRadius="10"
                        BorderBrush="#141C2B" BorderThickness="1">
                    <ListBox x:Name="ExclusionList"
                             Background="Transparent" BorderThickness="0"
                             Padding="4"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                </Border>

                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             x:Name="NewEntryBox"
                             KeyDown="NewEntryBox_KeyDown"
                             ToolTip="IP, CIDR, or domain — e.g. 192.168.0.0/16 or example.com"/>
                    <Button Grid.Column="2"
                            Content="{DynamicResource StrExclusionsAdd}"
                            Style="{StaticResource AccentBtn}"
                            Click="AddEntryClick"/>
                    <Button Grid.Column="4"
                            Content="{DynamicResource StrRemove}"
                            Style="{StaticResource DangerBtn}"
                            Click="RemoveEntryClick"/>
                </Grid>
            </Grid>

            <Border Grid.Row="2" Margin="16,10,16,14">
                <Grid>
                    <TextBlock x:Name="StatusLabel"
                               FontSize="11" Foreground="#3D5080"
                               VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right"
                            Content="{DynamicResource StrExclusionsSave}"
                            Style="{StaticResource AccentBtn}"
                            Click="SaveClick"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
