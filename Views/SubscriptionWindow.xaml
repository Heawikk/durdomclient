<Window x:Class="DurdomClient.Views.SubscriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import"
        Height="560" Width="560"
        Background="#080C14"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C9D1E0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0D1525"/>
            <Setter Property="Foreground" Value="#C9D1E0"/>
            <Setter Property="BorderBrush" Value="#1A2540"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#4F6BFF"/>
            <Setter Property="SelectionBrush" Value="#4F6BFF"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#4F6BFF"/>
            <Setter Property="Padding" Value="18,8"/>
        </Style>
        <Style x:Key="SubtleBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#141C2B"/>
            <Setter Property="Foreground" Value="#8892A4"/>
            <Setter Property="Padding" Value="12,7"/>
        </Style>
        <Style x:Key="Cap" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#3D4E6A"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#3D5080"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Border Background="#080C14" CornerRadius="16" BorderBrush="#1A2540" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#080C14" CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid Margin="16,0">
                    <TextBlock Text="{DynamicResource StrSubWindowTitle}"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#3D5080" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Style="{StaticResource SubtleBtn}"
                            Click="CloseWindow"
                            Padding="8,4">
                        <Grid Width="10" Height="10">
                            <Line X1="0" Y1="0" X2="10" Y2="10"
                                  Stroke="#4A5568" StrokeThickness="1.5"/>
                            <Line X1="10" Y1="0" X2="0" Y2="10"
                                  Stroke="#4A5568" StrokeThickness="1.5"/>
                        </Grid>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,4,16,16" x:Name="RootPanel">

                    <Border Background="#0D1525" CornerRadius="12" Padding="16" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource StrAddSubscription}" Style="{StaticResource Cap}"/>
                            <TextBlock Text="{DynamicResource StrSubName}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="SubNameBox" Margin="0,0,0,10" Text="My Subscription"/>
                            <TextBlock Text="{DynamicResource StrSubUrl}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="SubUrlBox" Margin="0,0,0,12"/>
                            <Button Content="{DynamicResource StrAddAndUpdate}"
                                    Style="{StaticResource AccentBtn}"
                                    HorizontalAlignment="Right"
                                    Click="AddSubscriptionClick"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#0D1525" CornerRadius="12" Padding="16" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource StrImportVless}" Style="{StaticResource Cap}"/>
                            <TextBlock Text="{DynamicResource StrVlessPaste}"
                                       Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="VlessUriBox"
                                     AcceptsReturn="True" Height="90"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     Margin="0,0,0,12"/>
                            <Button Content="{DynamicResource StrImport}"
                                    Style="{StaticResource AccentBtn}"
                                    HorizontalAlignment="Right"
                                    Click="ImportVlessUrisClick"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#0D1525" CornerRadius="12" Padding="16">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource StrActiveSubscriptions}" Style="{StaticResource Cap}"/>
                            <ListBox x:Name="SubList"
                                     Background="Transparent" BorderThickness="0"
                                     MaxHeight="130">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#8892A4"/>
                                        <Setter Property="Padding" Value="6,5"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#16203A"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#1B2E55"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                       FontWeight="Medium" Foreground="#C9D1E0"/>
                                            <TextBlock FontSize="10" Foreground="#3D5080" Margin="0,2,0,0">
                                                <Run Text="{Binding ServerCount}"/>
                                            <Run Text="{DynamicResource StrServersOf}"/>
                                                <Run Text="{Binding LastUpdated, StringFormat={}{0:yyyy-MM-dd HH:mm}}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="{DynamicResource StrUpdateAll}"
                                        Style="{StaticResource SubtleBtn}"
                                        Command="{Binding UpdateAllSubscriptionsCommand}"
                                        HorizontalAlignment="Stretch"/>
                                <Button Grid.Column="2" Content="{DynamicResource StrRemoveSelected}"
                                        Style="{StaticResource SubtleBtn}"
                                        Click="RemoveSubscriptionClick"
                                        Foreground="#E03A4A"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="StatusLabel" Margin="0,10,0,0"
                               FontSize="12" Foreground="#3D5080" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>

